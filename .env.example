# Site URL (OG 이미지, 리다이렉트 등에 사용)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Auth.js (NextAuth v5)
# 생성: npx auth secret
AUTH_SECRET=

# GitHub OAuth App (https://github.com/settings/developers)
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Supabase PostgreSQL
# Project Settings → Database → Connection string
# Transaction pooler (port 6543) — 앱 런타임용
POSTGRES_URL=
# Direct connection (port 5432) — 마이그레이션 / 스크립트용
POSTGRES_URL_NON_POOLING=

# 히든 테스트케이스 AES-256-GCM 키 (32바이트 / 64자 hex)
# NEXT_PUBLIC_* 이라 클라이언트 번들에 포함됨 — 강력한 비밀이 아닌 obfuscation 수준
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXT_PUBLIC_JUDGE_INPUT_KEY=

# Notion API — 공지사항 fetch (선택, 없으면 공지사항 기능 skip)
# NOTION_TOKEN: Notion Integration 시크릿 (https://www.notion.so/my-integrations)
# NOTION_NOTICES_DB_ID: 공지사항 Database ID (노션 페이지 URL의 마지막 32자)
NOTION_TOKEN=
NOTION_NOTICES_DB_ID=

# Cloudflare R2 — 공지사항 Notion 이미지 미러링(scripts/fetch-notices.ts) +
# clang WASM 자산 업로드(scripts/upload-clang-assets.ts)에 사용. 앱 런타임에는 불필요.
# 미설정 시 공지사항 이미지는 만료될 수 있는 Notion 원본 S3 URL을 그대로 사용함.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=
